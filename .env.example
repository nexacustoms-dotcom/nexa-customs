# Netlify / local environment variables
# Copy this to .env.local for local dev, set in Netlify dashboard for production

# Supabase (required for orders, image uploads, cross-device sync)
VITE_SUPA_URL=https://xxxx.supabase.co
VITE_SUPA_KEY=eyJhbGci...

# Stripe publishable key
VITE_STRIPE_PK=pk_live_...

# Telegram notifications
VITE_TG_TOKEN=
VITE_TG_CHAT=

# EmailJS
VITE_EJS_SVC=
VITE_EJS_TPL=
VITE_EJS_KEY=
VITE_EJS_TO=
